# Comma-separated absolute paths to project directories on this machine.
# Used by the verify-ecosystem and conveyour-changelog skills to locate codebases.
# Each path should point to the root of a project folder.
#
# Example:
# PROJECT_PATHS=/Users/you/Sites/vmc.conveyour.com,/Users/you/Sites/conveyour.com,/Users/you/Sites/webpdi.com,/Users/you/Sites/pdicy.com,/Users/you/Sites/timelayer,/Users/you/Sites/cf-workers/timelayer-api-gateway,/Users/you/Sites/cf-workers/vector-feature-flags
PROJECT_PATHS=

# SingleStore / MySQL database connection (used by query-runner skill)
SINGLESTORE_HOST=
SINGLESTORE_PORT=3306
SINGLESTORE_USER=
SINGLESTORE_PASSWORD=
SINGLESTORE_DB_NAME=

# ConveYour Admin RPC API (used by conveyour-admin skill)
CONVEYOUR_ADMIN_RPC_HOST=
CONVEYOUR_ADMIN_RPC_TOKEN=

# Quarry — shared documentation repository (used by quarry-expert skill)
# Absolute path to your local clone of git@gitlab.com:throwbo/quarry.git
QUARRY_PATH=
